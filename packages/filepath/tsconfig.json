{
    "extends": "../../tsconfig.json", // path to root
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["ESNext", "DOM"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "outDir": "./dist",
        "rootDir": "./src",
        "declaration": true,
        "declarationMap": true,
        "strict": true,
        "types": ["node"]
    },
    "include": ["src/**/*.ts"]
}