{
    "extends": "../../tsconfig.json", // path to root
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["ESNext", "DOM"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./dist",
        "composite": true,
        "rootDir": "./src",
        "declaration": true,
        "declarationMap": true,
        "strict": true,
        "types": ["node", "bun"]
    },
    "include": ["src/**/*.ts"]
}