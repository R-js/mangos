{
    "name": "@mangos/filepath",
    "version": "1.0.13",
    "author": "jacob bogers <jkfbogers@gmail.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/R-js/mangos.git",
        "directory": "packages/filepath"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "types": "./dist/index.d.ts",
    "main": "./dist/index.js",
    "devDependencies": {
        "@rollup/plugin-typescript": "12.3.0",
        "@types/node": "^25.7.0",
        "@vitest/coverage-v8": "^4.0.15",
        "tslib": "2.8.1",
        "typescript": "^5.9.3",
        "vite": "^7.2.7",
        "vitest": "^4.0.15"
    },
    "bugs": {
        "url": "https://github.com/R-js/mangos.git",
        "email": "jkfbogers@gmail.com"
    },
    "description": "filepath parses UNC (long and short and cmd aliases) local filesystem path, and unix paths, checks for invalid path characters",
    "engines": {
        "node": ">=v20.8.0"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md",
        "package.json"
    ],
    "homepage": "https://github.com/R-js/mangos/blob/master/packages/filepath/README.md",
    "keywords": [
        "file",
        "path",
        "unc",
        "dos",
        "linux",
        "device path",
        "universal naming convention",
        "file system",
        "lfs"
    ],
    "license": "Apache License 2.0",
    "scripts": {
        "prebuild": "npm run check",
        "build": "vite build",
        "prepack": "npm run build",
        "test": "vitest run --coverage",
        "check": "biome check .",
        "format": "biome format --write ."
    },
    "sideEffects": false,
    "type": "module"
}
