{
    "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
    "root": true,
    "files": {
        "includes": [
            "./packages/filepath/src/**/*.ts",
            "./packages/filepath/test/**/*.ts",
            "./biome.json",
            "./package.json",
            "./vite.config.ts",
            "./tsconfig.json",
            "!coverage",
            "!dist"
        ]
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "indentWidth": 4,
            "lineEnding": "lf",
            "lineWidth": 120
        },
        "linter": {
            "enabled": true
        }
    },
    "formatter": {
        "indentStyle": "space",
        "lineEnding": "lf",
        "indentWidth": 4
    },
    "json": {
        "formatter": {
            "enabled": true
        }
    },
    "linter": {
        "rules": {
            "suspicious": {
                "noExplicitAny": "off"
            },
            "style": {
                "noNonNullAssertion": "off"
            }
        }
    }
}
